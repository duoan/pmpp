{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/.venv/lib/python3.12/site-packages/torch/include",
                "${workspaceFolder}/.venv/lib/python3.12/site-packages/torch/include/torch/csrc/api/include",
                "/usr/include",
                "/usr/local/include",
                "/usr/local/cuda/include"
